# Environment Variables Template for Pre-Sales Monitoring System
# Copy this file to .env and fill in your actual values

# Google Sheets API Configuration
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# FreshSales CRM Configuration
FRESHSALES_API_KEY=your_freshsales_api_key_here
FRESHSALES_DOMAIN=your_domain.myfreshworks.com

# Slack Webhook (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Environment
NODE_ENV=development

# Database Configuration (if applicable)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=presales_monitoring
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Security
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_MINUTE=400