{
  "name": "pre-sales-monitoring",
  "version": "1.0.0",
  "description": "Automated monitoring and dashboard system for pre-sales activities",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:sheets": "node test_master_database.js",
    "test:forms": "node test_forms_integration.js",
    "test:forms:mapping": "node test_forms_integration.js --mapping",
    "test:forms:setup": "node test_forms_integration.js --setup",
    "test:notifications": "node test_notifications.js",
    "test:notifications:config": "node test_notifications.js config",
    "test:notifications:connectivity": "node test_notifications.js connectivity",
    "test:freshsales": "node test_freshsales.js",
    "test:freshsales:mock": "node test_freshsales.js --mock",
    "test:all": "npm run test:sheets && npm run test:forms && npm run test:notifications && npm run test:freshsales",
    "webhook:start": "node webhook-example.js",
    "webhook:dev": "nodemon webhook-example.js",
    "sync:forms": "node src/sheets/formsIntegration.js --sync",
    "sync:freshsales": "node src/api/freshsalesSync.js --sync",
    "dashboard:serve": "http-server src/dashboard -p 3000 -c-1",
    "health-check": "node scripts/health-check.js",
    "backup": "node scripts/backup-data.js",
    "deploy:dashboard": "echo 'Upload src/dashboard/ to dashboard.giftedworld.org'",
    "setup:env": "node scripts/setup-environment.js",
    "deploy:scripts": "node deploy_scripts_automation.js",
    "deploy:scripts:setup": "npm install puppeteer readline-sync chalk && npm run deploy:scripts",
    "deploy:scripts:test": "node -e \"console.log('Testing automation dependencies...'); require('puppeteer'); require('readline-sync'); require('chalk'); console.log('✅ All automation dependencies available');\""
  },
  "keywords": [
    "pre-sales",
    "monitoring",
    "dashboard",
    "google-sheets",
    "freshsales",
    "automation"
  ],
  "author": "Rajesh Panchanathan",
  "license": "ISC",
  "dependencies": {
    "@slack/webhook": "^7.0.6",
    "axios": "^1.12.2",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.3.0",
    "google-spreadsheet": "^5.0.2",
    "googleapis": "^126.0.1",
    "helmet": "^7.0.0",
    "moment": "^2.29.4",
    "node-cron": "^3.0.2",
    "nodemailer": "^7.0.6",
    "playwright": "^1.55.1",
    "puppeteer": "^21.6.1",
    "readline-sync": "^1.4.10",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "http-server": "^14.1.1",
    "jest": "^29.6.4",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
